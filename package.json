{
  "name": "gift-ledger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node ./api/server.mjs",
    "app:start": "concurrently -k \"npm:serve:web\" \"npm:serve:api\"",
    "serve:web": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "serve:api": "node ./api/server.mjs",
    "build": "tsc && vite build",
    "preview": "concurrently -k \"vite preview\" \"npm:dev:api\""
  },
  "devDependencies": {
    "@types/opentype.js": "^1.3.9",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "opentype.js": "^1.3.4",
    "xlsx": "^0.18.5"
  }
}
